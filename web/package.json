{
  "name": "veln-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "qa": "npm run check && npm run lint && npm run format:check && npm run test && npm run build",
    "qa:fix": "npm run lint:fix && npm run format && npm run qa"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^2.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^2.0.0",
    "vue-tsc": "^3.2.5"
  }
}
